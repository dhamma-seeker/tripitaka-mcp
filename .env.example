# =============================================================================
# Tripitaka MCP Server — Environment Variables Example
# =============================================================================
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ไขค่าตามต้องการ
#   cp .env.example .env
#
# หลังสร้าง .env แล้ว:
#   chmod 600 .env        # จำกัดสิทธิ์อ่านเฉพาะ owner
#
# ⚠️ ห้าม commit .env เข้า git (อยู่ใน .gitignore แล้ว)

# --- Database (บังคับตั้งค่า) -------------------------------------------------
# POSTGRES_PASSWORD: สร้างรหัสผ่านสุ่มที่แข็งแรง เช่น
#   openssl rand -base64 32
POSTGRES_DB=tripitaka_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_RANDOM_PASSWORD

# DATABASE_URL ต้องตรงกับค่าด้านบน
# - dev (รันบน host):     postgresql://admin:CHANGE_ME@localhost:5432/tripitaka_db
# - docker compose:       postgresql://admin:CHANGE_ME@db:5432/tripitaka_db
DATABASE_URL=postgresql://admin:CHANGE_ME_GENERATE_RANDOM_PASSWORD@localhost:5432/tripitaka_db

# --- Embedding Model ---------------------------------------------------------
# ชื่อ model จาก HuggingFace Hub สำหรับ sentence-transformers
# แนะนำเริ่มต้น: paraphrase-multilingual-MiniLM-L12-v2 (เบา, 118M)
# ตัวเลือกอื่น: jina-embeddings-v5-text-small (ดีกว่า, 596M)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSIONS=384

# --- MCP Server --------------------------------------------------------------
# MCP_TRANSPORT: stdio (Claude Desktop/Cursor) หรือ sse (HTTP)
MCP_TRANSPORT=stdio
# สำหรับ SSE mode — bind localhost เท่านั้น ให้ reverse proxy ทำ TLS+auth
# MCP_HOST=127.0.0.1
# MCP_PORT=8080

# --- Data --------------------------------------------------------------------
BILARA_DATA_PATH=./data/bilara-data
