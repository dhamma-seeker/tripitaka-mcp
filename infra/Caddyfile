# =============================================================================
# Tripitaka MCP — Caddy reverse proxy + rate limit
# =============================================================================
# ต้องการ caddy ที่ build มาพร้อมกับ plugin github.com/mholt/caddy-ratelimit
# ดู infra/Dockerfile.caddy
#
# ตั้งค่า TRIPITAKA_DOMAIN ใน .env ก่อน up
# เช่น TRIPITAKA_DOMAIN=mcp.example.org

{
    # ปิด admin API ออกจาก network — เปิดเฉพาะ localhost ภายใน container
    admin off

    # เก็บ log แบบ structured JSON
    log {
        output stdout
        format json
        level INFO
    }

    # เปิด rate_limit plugin (ต้อง build caddy พร้อม plugin นี้)
    order rate_limit before reverse_proxy
}

{$TRIPITAKA_DOMAIN} {
    encode zstd gzip

    # --- security headers -----------------------------------------------------
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "no-referrer"
        # ไม่ leak Caddy version
        -Server
    }

    # --- rate limit (เน้น per-IP เพราะเป็น free public service) ---------------
    # zone "sse_per_ip": 10 requests / 10 วินาที / ip → burst-friendly
    # zone "sse_per_ip_slow": 60 requests / 1 นาที / ip → prevent sustained hammering
    # ถ้าเกิน → HTTP 429
    rate_limit {
        distributed
        zone sse_per_ip {
            key {client_ip}
            events 10
            window 10s
        }
        zone sse_per_ip_slow {
            key {client_ip}
            events 60
            window 1m
        }
    }

    # --- healthcheck (เปิดไม่ rate limit) -----------------------------------
    @health path /health /healthz
    handle @health {
        respond "ok" 200
    }

    # --- topics: static markdown pages (curated reference content) ----------
    # serve markdown ดิบ — modern AI clients render markdown ใน chat ได้, search
    # engines index content จริง (ไม่ใช่แค่ homepage).
    # ใช้ handle_path เพื่อ strip /topics prefix ก่อน file_server หา file ใน
    # /var/www/topics (ไม่งั้น Caddy หา /var/www/topics/topics/*.md ซึ่งไม่มี
    # → fall ไป /README.md → ทุก path ตอบเหมือนกัน)
    handle_path /topics* {
        root * /var/www/topics
        # Serve .md as text/plain (browsers render readable; AI clients fetch ok)
        @markdown path *.md
        header @markdown Content-Type "text/plain; charset=utf-8"
        # CORS open — เป็น public reference content
        header Access-Control-Allow-Origin "*"
        # cache 1 hour — content เปลี่ยนไม่บ่อย
        header Cache-Control "public, max-age=3600"
        # ถ้า request ลงท้ายด้วย / หรือ empty → ส่ง README.md
        try_files {path} {path}.md {path}/README.md /README.md
        file_server
    }

    # --- legacy SSE transport (deprecated by MCP spec 2025-03-26) -----------
    # FastMCP serve: GET /sse (event stream) + POST /messages/{session_id}
    # คงไว้เพื่อ backward compat กับ clients เก่า ลบเมื่อ migrate ครบ
    @sse path /sse /messages /messages/*
    handle @sse {
        reverse_proxy mcp-server:8080 {
            # SSE ต้อง flush ทันที + keep connection นาน
            flush_interval -1
            transport http {
                read_timeout 5m
                write_timeout 5m
            }
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
        }
    }

    # --- canonical Streamable HTTP transport (MCP spec 2025-03-26) ----------
    # FastMCP serve: /mcp (POST + GET, response อาจ stream SSE)
    @mcp path /mcp /mcp/*
    handle @mcp {
        reverse_proxy mcp-server-http:8080 {
            flush_interval -1
            transport http {
                read_timeout 5m
                write_timeout 5m
            }
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
        }
    }

    # --- fallback: unmatched paths → canonical (Streamable HTTP) ------------
    handle {
        reverse_proxy mcp-server-http:8080 {
            flush_interval -1
            transport http {
                read_timeout 5m
                write_timeout 5m
            }
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
        }
    }

    # --- body size limit ------------------------------------------------------
    request_body {
        max_size 256KB
    }
}
