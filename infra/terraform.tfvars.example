# Copy this file to terraform.tfvars and fill in your values
# คัดลอกเป็น terraform.tfvars แล้วแก้ค่า
#   cp terraform.tfvars.example terraform.tfvars

# --- บังคับตั้งค่า ------------------------------------------------------------
do_token = "dop_v1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# --- SSH key ---------------------------------------------------------------
# แนะนำสร้าง key ใหม่สำหรับ production แยกจาก personal key:
#   ssh-keygen -t ed25519 -f ~/.ssh/tripitaka_prod -C "tripitaka-deploy"
public_key_path = "~/.ssh/tripitaka_prod.pub"
ssh_key_name    = "tripitaka-mcp-key"

# --- Droplet size ----------------------------------------------------------
# s-2vcpu-4gb  = $24/mo (แนะนำขั้นต่ำ มี swap 2GB ช่วยเสริม)
# s-2vcpu-2gb  = $18/mo (ใช้ได้แต่เสี่ยง OOM ตอนโหลด embedding)
# s-1vcpu-2gb  = $12/mo (ไม่แนะนำ ยกเว้นไม่ได้ load embedding เอง)
droplet_size = "s-2vcpu-4gb"

# --- Region ----------------------------------------------------------------
# sgp1 = Singapore  (latency ต่ำสุดสำหรับไทย)
# blr1 = Bangalore  (ทางเลือก)
region = "sgp1"

# --- Domain ----------------------------------------------------------------
# โดเมนที่เพิ่มใน DigitalOcean DNS แล้ว — ถ้าใช้ Cloudflare ค่อยย้าย NS
domain_name = "tripitaka-mcp.com"

# --- SSH allowlist (แนะนำจำกัด IP ของคุณเท่านั้น) ---------------------------
# ดู IP ตัวเอง: curl ifconfig.me
# แล้วใส่เป็น "A.B.C.D/32"
# ถ้ายังไม่พร้อมลด scope → ใช้ค่า default ได้ก่อน (fail2ban ชั้น 2)
# ssh_allowed_cidrs = ["YOUR.HOME.IP.HERE/32"]
